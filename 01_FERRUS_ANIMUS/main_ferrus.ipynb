    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "# [INTEL] Cellule 5 — INTEL-SKELETON (pre_parse + Claude via Blender headless)\n",
    "# Lance intel_skeleton.py dans Blender pour chaque FBX.\n",
    "# Necessite AI_GATEWAY_API_KEY dans les Secrets Colab (optionnel).\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "import subprocess, time\n",
    "\n",
    "# Recuperer la cle API depuis les Secrets Colab si disponible\n",
    "try:\n",
    "    from google.colab import userdata\n",
    "    API_KEY = userdata.get(\"AI_GATEWAY_API_KEY\")\n",
    "    print(\"[API] AI_GATEWAY_API_KEY detecte dans les Secrets Colab.\")\n",
    "except Exception:\n",
    "    API_KEY = None\n",
    "    print(\"[API] AI_GATEWAY_API_KEY absent — mode fallback statique.\")\n",
    "\n",
    "def run_intel_skeleton_via_blender(person: dict) -> dict:\n",
    "    \"\"\"Lance intel_skeleton.py dans Blender pour un FBX. Retourne le JSON analyse.\"\"\"\n",
    "    stem       = person[\"fbx_stem\"]\n",
    "    cache_path = f\"{DIR_CACHE}/intel_skeleton_{stem}.json\"\n",
    "\n",
    "    if os.path.exists(cache_path):\n",
    "        print(f\"  [CACHE] {stem} — lecture cache, zero token API\")\n",
    "        with open(cache_path) as f:\n",
    "            return json.load(f)\n",
    "\n",
    "    # Script wrapper temporaire pour Blender\n",
    "    wrapper = f\"\"\"import sys, os\n",
    "sys.path.insert(0, {repr(INTEL_SCRIPTS)})\n",
    "from intel_skeleton import run_intel_skeleton\n",
    "\n",
    "api_key = {repr(API_KEY)}\n",
    "results = run_intel_skeleton(\n",
    "    fbx_files  = [{repr(person['fbx_path'])}],\n",
    "    output_dir = {repr(DIR_CACHE)},\n",
    "    api_key    = api_key,\n",
    ")\n",
    "print('[INTEL-SKELETON] OK')\n",
    "\"\"\"\n",
    "    tmp = f\"{DIR_TMP}/run_intel_{stem}.py\"\n",
    "    with open(tmp, \"w\") as f:\n",
    "        f.write(wrapper)\n",
    "\n",
    "    t0  = time.time()\n",
    "    res = subprocess.run(\n",
    "        [BLENDER_PATH, \"--background\", \"--python\", tmp],\n",
    "        capture_output=True, text=True, timeout=180\n",
    "    )\n",
    "\n",
    "    if res.returncode != 0:\n",
    "        print(f\"  [ERREUR] intel_skeleton : {res.stderr[-800:]}\")\n",
    "        return None\n",
    "\n",
    "    print(f\"  [OK] {stem} analyse en {time.time()-t0:.1f}s\")\n",
    "\n",
    "    with open(cache_path) as f:\n",
    "        return json.load(f)\n",
    "\n",
    "\n",
    "print(\"[INTEL-SKELETON] Analyse des FBX en cours...\")\n",
    "INTEL_SKELETON_RESULTS = {}\n",
    "\n",
    "for person in MANIFEST:\n",
    "    print(f\"\\n  Traitement : {person['fbx_file']}\")\n",
    "    result = run_intel_skeleton_via_blender(person)\n",
    "    if result:\n",
    "        INTEL_SKELETON_RESULTS[person[\"fbx_stem\"]] = result\n",
    "        q = result[\"qualite_fcurves\"]\n",
    "        print(f\"  score={result['qualite_fcurves']['score_global']} | \"\n",
    "              f\"corrections={result['corrections_requises']}\")\n",
    "\n",
    "print(f\"\\n[INTEL-SKELETON] {len(INTEL_SKELETON_RESULTS)}/{len(MANIFEST)} FBX analyses.\")\n"
   ]
  },
