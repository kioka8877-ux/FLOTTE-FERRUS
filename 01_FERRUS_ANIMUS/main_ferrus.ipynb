    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "# [INTEL] Cellule 4 — Injection JSON INTEL-VISION (Gemini Chat)\n",
    "# Collez le JSON fourni par Gemini. Laissez vide si non disponible.\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "import ipywidgets as widgets\n",
    "from IPython.display import display\n",
    "\n",
    "INTEL_VISION_PATH = f\"{DIR_CACHE}/intel_vision.json\"\n",
    "INTEL_VISION_DATA = [None]\n",
    "\n",
    "print(\"=== INTEL-VISION (Gemini Chat) ===\")\n",
    "print(\"Metaprompt : FERRUS_INTEL_VISION_GEMINI_METAPROMPT.md\")\n",
    "print(\"Laissez vide pour utiliser uniquement INTEL-SKELETON (mode sans Gemini).\")\n",
    "print()\n",
    "\n",
    "json_input = widgets.Textarea(\n",
    "    placeholder='{\"scene_id\": \"video_01\", \"video\": {...}, \"personnes\": [...], ...}',\n",
    "    layout=widgets.Layout(width='100%', height='250px')\n",
    ")\n",
    "btn = widgets.Button(description=\"Valider JSON Gemini\", button_style=\"primary\")\n",
    "out = widgets.Output()\n",
    "\n",
    "def on_validate(b):\n",
    "    with out:\n",
    "        out.clear_output()\n",
    "        raw = json_input.value.strip()\n",
    "        if not raw:\n",
    "            print(\"[SKIP] Mode sans Gemini — camera_follow et mask_limbs desactives par defaut.\")\n",
    "            INTEL_VISION_DATA[0] = None\n",
    "            return\n",
    "        try:\n",
    "            data = json.loads(raw)\n",
    "            with open(INTEL_VISION_PATH, \"w\", encoding=\"utf-8\") as f:\n",
    "                json.dump(data, f, ensure_ascii=False, indent=2)\n",
    "            INTEL_VISION_DATA[0] = data\n",
    "            nb_p = len(data.get(\"personnes\", []))\n",
    "            suivi = data.get(\"instructions_camera\", {}).get(\"type_suivi\", \"?\")\n",
    "            print(f\"[OK] JSON INTEL-VISION valide : {nb_p} personne(s) | suivi={suivi}\")\n",
    "            for p in data.get(\"personnes\", []):\n",
    "                print(f\"  P{p['person_id']} : corps={p['corps_visible']} | \"\n",
    "                      f\"qualite={p['qualite_estimee']} | \"\n",
    "                      f\"hors_cadre={p.get('membres_hors_cadre', [])}\")\n",
    "        except json.JSONDecodeError as e:\n",
    "            print(f\"[ERREUR] JSON invalide : {e}\")\n",
    "\n",
    "btn.on_click(on_validate)\n",
    "display(json_input, btn, out)\n"
   ]
  },
