   "source": [
    "---\n",
    "## OUTPUT — Retargeting Roblox R15\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "# [OUTPUT] Cellule 8 — Retargeting DeepMotion → Roblox R15\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "\n",
    "OUTPUT_RESULTS = {}\n",
    "\n",
    "for person in MANIFEST:\n",
    "    pid = person[\"person_id\"]\n",
    "\n",
    "    if pid not in EXEC_RESULTS:\n",
    "        print(f\"[SKIP] P{pid} — EXEC absent\")\n",
    "        continue\n",
    "\n",
    "    fbx_in    = EXEC_RESULTS[pid][\"fbx_exec_out\"]\n",
    "    plan_path = PLANS[pid][\"plan_path\"]\n",
    "    fbx_out   = person[\"fbx_out\"]\n",
    "\n",
    "    print(f\"\\n[OUTPUT] P{pid} — Retargeting R15...\")\n",
    "    t0  = time.time()\n",
    "\n",
    "    res = subprocess.run(\n",
    "        [\n",
    "            BLENDER_PATH, \"--background\", \"--python\",\n",
    "            f\"{OUT_SCRIPTS}/retarget_r15.py\", \"--\",\n",
    "            \"--fbx-in\",  fbx_in,\n",
    "            \"--plan\",    plan_path,\n",
    "            \"--fbx-out\", fbx_out,\n",
    "        ],\n",
    "        capture_output=True, text=True, timeout=300\n",
    "    )\n",
    "    dt = round(time.time() - t0, 1)\n",
    "\n",
    "    if res.returncode != 0:\n",
    "        print(f\"  [ERREUR] retarget_r15 ({dt}s) :\\n{res.stderr[-600:]}\")\n",
    "        OUTPUT_RESULTS[pid] = {\"status\": \"error\", \"duree_s\": dt}\n",
    "        continue\n",
    "\n",
    "    print(f\"  [OK] FBX R15 exporte : {fbx_out} ({dt}s)\")\n",
    "    OUTPUT_RESULTS[pid] = {\n",
    "        \"status\":   \"ok\",\n",
    "        \"fbx_out\":  fbx_out,\n",
    "        \"duree_s\":  dt,\n",
    "    }\n",
    "\n",
    "print(f\"\\n[OUTPUT] {sum(1 for r in OUTPUT_RESULTS.values() if r['status']=='ok')}/\"\n",
    "      f\"{len(MANIFEST)} FBX R15 exportes.\")\n"
   ]
  },
  {
   "cell_type": "markdown",
