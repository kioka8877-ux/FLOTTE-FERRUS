    "---\n",
    "## INTEL — Analyse de la scene\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "# [INTEL] Cellule 3 — Scan IN/ + Manifest\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "import json, glob\n",
    "\n",
    "def scan_fbx_files():\n",
    "    fbx_files = sorted(glob.glob(f\"{DIR_IN}/*.fbx\"))\n",
    "    if not fbx_files:\n",
    "        raise FileNotFoundError(f\"Aucun fichier .fbx dans {DIR_IN}\")\n",
    "\n",
    "    manifest = []\n",
    "    for i, path in enumerate(fbx_files, 1):\n",
    "        size_mb = round(os.path.getsize(path) / (1024 * 1024), 2)\n",
    "        stem    = os.path.splitext(os.path.basename(path))[0]\n",
    "        manifest.append({\n",
    "            \"person_id\":  i,\n",
    "            \"fbx_file\":   os.path.basename(path),\n",
    "            \"fbx_path\":   path,\n",
    "            \"fbx_stem\":   stem,\n",
    "            \"fbx_out\":    f\"{DIR_OUT}/ferrus_P{i}.fbx\",\n",
    "            \"taille_mb\":  size_mb,\n",
    "        })\n",
    "\n",
    "    manifest_path = f\"{DIR_CACHE}/manifest.json\"\n",
    "    with open(manifest_path, \"w\") as f:\n",
    "        json.dump(manifest, f, indent=2, ensure_ascii=False)\n",
    "\n",
    "    print(f\"[MANIFEST] {len(manifest)} fichier(s) FBX detecte(s) dans IN/ :\")\n",
    "    for p in manifest:\n",
    "        print(f\"  P{p['person_id']} : {p['fbx_file']} ({p['taille_mb']} Mo)\")\n",
    "\n",
    "    return manifest\n",
    "\n",
    "MANIFEST = scan_fbx_files()\n"
   ]
  },
