   "source": [
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "# [INTEL] Cellule 6 — Merge INTEL → plan_corrections.json\n",
    "# Fusionne intel_skeleton + intel_vision → un plan par personne.\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "\n",
    "def merge_intel(person: dict, skeleton: dict, vision_data: dict | None) -> dict:\n",
    "    \"\"\"\n",
    "    Construit plan_corrections.json pour une personne.\n",
    "\n",
    "    - skeleton  : sortie intel_skeleton (analyse Claude ou fallback)\n",
    "    - vision_data : sortie Gemini intel_vision (None si absent)\n",
    "    \"\"\"\n",
    "    qf = skeleton.get(\"qualite_fcurves\", {})\n",
    "\n",
    "    # --- INTEL-SKELETON : corrections EXEC requises ---\n",
    "    corrections_requises = skeleton.get(\"corrections_requises\", [])\n",
    "\n",
    "    # smooth_fcurves\n",
    "    smooth_enabled = \"smooth_fcurves\" in corrections_requises\n",
    "    jitter_bones   = qf.get(\"jitter_bones\", [])\n",
    "    if smooth_enabled and not jitter_bones:\n",
    "        jitter_bones = [\"l_hand_JNT\", \"r_hand_JNT\", \"head_JNT\"]\n",
    "    smooth_intensite = min(1.0, round(qf.get(\"jitter_score\", 0.5) + 0.2, 1))\n",
    "\n",
    "    # stabilize_hips\n",
    "    hips_enabled = \"stabilize_hips\" in corrections_requises\n",
    "    derive       = qf.get(\"derive_hanches\", {})\n",
    "\n",
    "    # remove_foot_slide\n",
    "    foot_enabled = \"remove_foot_slide\" in corrections_requises\n",
    "    foot_slide   = qf.get(\"foot_slide\", {})\n",
    "    seuil_cm     = max(\n",
    "        foot_slide.get(\"pied_gauche_delta_max_cm\", 0.0),\n",
    "        foot_slide.get(\"pied_droit_delta_max_cm\",  0.0),\n",
    "    )\n",
    "    seuil_cm = round(seuil_cm * 0.5, 1) if seuil_cm > 0 else 5.0\n",
    "\n",
    "    # --- INTEL-VISION : camera_follow + mask_limbs ---\n",
    "    camera_actif    = False\n",
    "    type_suivi      = \"smooth_follow\"\n",
    "    cible_person_id = person[\"person_id\"]\n",
    "    membres_masquer = []\n",
    "\n",
    "    if vision_data:\n",
    "        instr = vision_data.get(\"instructions_camera\", {})\n",
    "        # camera_follow active si cette personne est la cible principale\n",
    "        if instr.get(\"suivre_personne_id\") == person[\"person_id\"]:\n",
    "            camera_actif = True\n",
    "            type_suivi   = instr.get(\"type_suivi\", \"smooth_follow\")\n",
    "\n",
    "        # mask_limbs : membres hors cadre pour cette personne\n",
    "        for p_vision in vision_data.get(\"personnes\", []):\n",
    "            if p_vision.get(\"fbx_file\") == person[\"fbx_file\"]:\n",
    "                membres_masquer = p_vision.get(\"membres_hors_cadre\", [])\n",
    "                break\n",
    "\n",
    "    plan = {\n",
    "        \"person_id\":            person[\"person_id\"],\n",
    "        \"fbx_input\":            person[\"fbx_path\"],\n",
    "        \"fbx_output\":           person[\"fbx_out\"],\n",
    "        \"score_qualite_input\":  skeleton[\"qualite_fcurves\"][\"score_global\"],\n",
    "        \"corrections_exec\": {\n",
    "            \"smooth_fcurves\": {\n",
    "                \"enabled\":      smooth_enabled,\n",
    "                \"bones_cibles\": jitter_bones,\n",
    "                \"intensite\":    smooth_intensite,\n",
    "            },\n",
    "            \"stabilize_hips\": {\n",
    "                \"enabled\":                  hips_enabled,\n",
    "                \"correction_verticale_cm\":  derive.get(\"delta_vertical_cm\", 0.0),\n",
    "                \"direction\":                derive.get(\"direction\", \"stable\"),\n",
    "            },\n",
    "            \"remove_foot_slide\": {\n",
    "                \"enabled\":  foot_enabled,\n",
    "                \"seuil_cm\": seuil_cm,\n",
    "            },\n",
    "            \"camera_follow\": {\n",
    "                \"actif\":           camera_actif,\n",
    "                \"cible_person_id\": cible_person_id,\n",
    "                \"type_suivi\":      type_suivi,\n",
    "            },\n",
    "            \"mask_limbs\": {\n",
    "                \"actif\":              bool(membres_masquer),\n",
    "                \"membres_a_masquer\":  membres_masquer,\n",
    "            },\n",
    "        },\n",
    "        \"retargeting_r15\": {\"enabled\": True},\n",
    "    }\n",
    "\n",
    "    return plan\n",
    "\n",
    "\n",
    "print(\"[MERGE] Construction des plans de correction...\")\n",
    "PLANS = {}\n",
    "\n",
    "for person in MANIFEST:\n",
    "    stem     = person[\"fbx_stem\"]\n",
    "    skeleton = INTEL_SKELETON_RESULTS.get(stem)\n",
    "    if not skeleton:\n",
    "        print(f\"  [SKIP] {stem} — analyse INTEL absente\")\n",
    "        continue\n",
    "\n",
    "    plan      = merge_intel(person, skeleton, INTEL_VISION_DATA[0])\n",
    "    plan_path = f\"{DIR_CACHE}/plan_corrections_P{person['person_id']}.json\"\n",
    "\n",
    "    with open(plan_path, \"w\", encoding=\"utf-8\") as f:\n",
    "        json.dump(plan, f, ensure_ascii=False, indent=2)\n",
    "\n",
    "    PLANS[person[\"person_id\"]] = {\"plan\": plan, \"plan_path\": plan_path}\n",
    "\n",
    "    ce = plan[\"corrections_exec\"]\n",
    "    print(f\"\\n  P{person['person_id']} — {person['fbx_file']} :\")\n",
    "    print(f\"    smooth     : {ce['smooth_fcurves']['enabled']} | \"\n",
    "          f\"bones={len(ce['smooth_fcurves']['bones_cibles'])}\")\n",
    "    print(f\"    hips       : {ce['stabilize_hips']['enabled']} | \"\n",
    "          f\"delta={ce['stabilize_hips']['correction_verticale_cm']}cm\")\n",
    "    print(f\"    foot_slide : {ce['remove_foot_slide']['enabled']} | \"\n",
    "          f\"seuil={ce['remove_foot_slide']['seuil_cm']}cm\")\n",
    "    print(f\"    camera     : {ce['camera_follow']['actif']} | \"\n",
    "          f\"type={ce['camera_follow']['type_suivi']}\")\n",
    "    print(f\"    mask       : {ce['mask_limbs']['actif']} | \"\n",
    "          f\"membres={ce['mask_limbs']['membres_a_masquer']}\")\n",
    "\n",
    "print(f\"\\n[MERGE] {len(PLANS)}/{len(MANIFEST)} plans generes.\")\n"
   ]
  },
