   "source": [
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "# [EXEC] Cellule 7 — 5 operations (smooth → hips → foot → mask → camera)\n",
    "# Chaque operation consomme la sortie de la precedente.\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "\n",
    "EXEC_OPS = [\n",
    "    (\"smooth_fcurves\",   \"smooth_fcurves.py\"),\n",
    "    (\"stabilize_hips\",   \"stabilize_hips.py\"),\n",
    "    (\"remove_foot_slide\",\"remove_foot_slide.py\"),\n",
    "    (\"mask_limbs\",       \"mask_limbs.py\"),\n",
    "    (\"camera_follow\",    \"camera_follow.py\"),\n",
    "]\n",
    "\n",
    "def run_exec_op(op_name: str, script: str, fbx_in: str,\n",
    "                plan_path: str, fbx_out: str) -> bool:\n",
    "    \"\"\"Lance une operation EXEC via Blender headless. Retourne True si OK.\"\"\"\n",
    "    t0  = time.time()\n",
    "    res = subprocess.run(\n",
    "        [\n",
    "            BLENDER_PATH, \"--background\", \"--python\",\n",
    "            f\"{EXEC_SCRIPTS}/{script}\", \"--\",\n",
    "            \"--fbx-in\",  fbx_in,\n",
    "            \"--plan\",    plan_path,\n",
    "            \"--fbx-out\", fbx_out,\n",
    "        ],\n",
    "        capture_output=True, text=True, timeout=240\n",
    "    )\n",
    "    dt = round(time.time() - t0, 1)\n",
    "\n",
    "    if res.returncode != 0:\n",
    "        print(f\"    [ERREUR] {op_name} ({dt}s) :\\n{res.stderr[-600:]}\")\n",
    "        return False\n",
    "\n",
    "    # Extraire la derniere ligne de statut du script\n",
    "    lines  = [l for l in res.stdout.splitlines() if op_name in l.lower() or \"status\" in l.lower()]\n",
    "    status = lines[-1] if lines else \"OK\"\n",
    "    print(f\"    [{dt}s] {status}\")\n",
    "    return True\n",
    "\n",
    "\n",
    "EXEC_RESULTS = {}\n",
    "\n",
    "for person in MANIFEST:\n",
    "    pid  = person[\"person_id\"]\n",
    "    stem = person[\"fbx_stem\"]\n",
    "\n",
    "    if pid not in PLANS:\n",
    "        print(f\"[SKIP] P{pid} — plan absent\")\n",
    "        continue\n",
    "\n",
    "    plan_path = PLANS[pid][\"plan_path\"]\n",
    "    print(f\"\\n[EXEC] P{pid} — {person['fbx_file']}\")\n",
    "\n",
    "    current_fbx = person[\"fbx_path\"]\n",
    "    op_reports  = {}\n",
    "    t_total     = time.time()\n",
    "\n",
    "    for i, (op_name, script) in enumerate(EXEC_OPS):\n",
    "        next_fbx = f\"{DIR_TMP}/P{pid}_exec{i+1}_{op_name}.fbx\"\n",
    "        print(f\"  Op.{i+1} {op_name}...\")\n",
    "\n",
    "        ok = run_exec_op(op_name, script, current_fbx, plan_path, next_fbx)\n",
    "        if ok:\n",
    "            current_fbx       = next_fbx\n",
    "            op_reports[op_name] = \"ok\"\n",
    "        else:\n",
    "            print(f\"  [WARN] {op_name} echoue — FBX precedent conserve\")\n",
    "            op_reports[op_name] = \"error\"\n",
    "\n",
    "    EXEC_RESULTS[pid] = {\n",
    "        \"fbx_exec_out\": current_fbx,\n",
    "        \"ops\":          op_reports,\n",
    "        \"duree_exec_s\": round(time.time() - t_total, 1),\n",
    "    }\n",
    "\n",
    "    print(f\"  [EXEC P{pid}] Termine en {EXEC_RESULTS[pid]['duree_exec_s']}s\")\n",
    "    print(f\"  FBX corrige : {current_fbx}\")\n",
    "\n",
    "print(f\"\\n[EXEC] {len(EXEC_RESULTS)}/{len(MANIFEST)} personnes corrigees.\")\n"
   ]
  },
