   "source": [
    "---\n",
    "## RAPPORT — Bilan de campagne\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "# [RAPPORT] Cellule 9 — Generation rapport.json + affichage bilan\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "import datetime\n",
    "\n",
    "rapport = {\n",
    "    \"pipeline\":           \"FERRUS ANIMUS v1.0\",\n",
    "    \"date\":               datetime.datetime.now().isoformat(timespec=\"seconds\"),\n",
    "    \"nb_personnes\":       len(MANIFEST),\n",
    "    \"nb_fbx_r15_exportes\": sum(1 for r in OUTPUT_RESULTS.values() if r.get(\"status\") == \"ok\"),\n",
    "    \"personnes\": [],\n",
    "}\n",
    "\n",
    "for person in MANIFEST:\n",
    "    pid       = person[\"person_id\"]\n",
    "    skeleton  = INTEL_SKELETON_RESULTS.get(person[\"fbx_stem\"], {})\n",
    "    plan      = PLANS.get(pid, {}).get(\"plan\", {})\n",
    "    exec_res  = EXEC_RESULTS.get(pid, {})\n",
    "    out_res   = OUTPUT_RESULTS.get(pid, {})\n",
    "\n",
    "    entry = {\n",
    "        \"person_id\":            pid,\n",
    "        \"fbx_input\":            person[\"fbx_file\"],\n",
    "        \"fbx_output\":           person[\"fbx_out\"],\n",
    "        \"score_qualite_input\":  skeleton.get(\"qualite_fcurves\", {}).get(\"score_global\", 0.0),\n",
    "        \"corrections_requises\": skeleton.get(\"corrections_requises\", []),\n",
    "        \"corrections_appliquees\": exec_res.get(\"ops\", {}),\n",
    "        \"duree_exec_s\":         exec_res.get(\"duree_exec_s\", 0),\n",
    "        \"duree_retarget_s\":     out_res.get(\"duree_s\", 0),\n",
    "        \"r15_export\":           out_res.get(\"status\") == \"ok\",\n",
    "        \"fbx_r15_chemin\":       out_res.get(\"fbx_out\", \"\"),\n",
    "    }\n",
    "    rapport[\"personnes\"].append(entry)\n",
    "\n",
    "rapport_path = f\"{DIR_OUT}/rapport.json\"\n",
    "with open(rapport_path, \"w\", encoding=\"utf-8\") as f:\n",
    "    json.dump(rapport, f, ensure_ascii=False, indent=2)\n",
    "\n",
    "# ── Affichage bilan ──────────────────────────────────────────────────────────\n",
    "print(\"\\n\" + \"═\" * 60)\n",
    "print(\" FERRUS ANIMUS — RAPPORT FINAL\")\n",
    "print(\"═\" * 60)\n",
    "print(f\"  Personnes traitees : {rapport['nb_personnes']}\")\n",
    "print(f\"  FBX R15 exportes   : {rapport['nb_fbx_r15_exportes']}\")\n",
    "print()\n",
    "\n",
    "for entry in rapport[\"personnes\"]:\n",
    "    pid    = entry[\"person_id\"]\n",
    "    ok     = \"[OK]\" if entry[\"r15_export\"] else \"[ERREUR]\"\n",
    "    duree  = entry[\"duree_exec_s\"] + entry[\"duree_retarget_s\"]\n",
    "    print(f\"  P{pid} {ok} | score_input={entry['score_qualite_input']} | \"\n",
    "          f\"corrections={entry['corrections_requises']} | \"\n",
    "          f\"duree={duree:.1f}s\")\n",
    "    if entry[\"r15_export\"]:\n",
    "        print(f\"     → {entry['fbx_r15_chemin']}\")\n",
    "\n",
    "print()\n",
    "print(f\"  Rapport complet : {rapport_path}\")\n",
    "print(\"═\" * 60)\n",
    "print()\n",
    "print(\"  Fichiers dans OUT/ :\")\n",
    "for f in sorted(os.listdir(DIR_OUT)):\n",
    "    size = round(os.path.getsize(f\"{DIR_OUT}/{f}\") / (1024*1024), 2)\n",
    "    print(f\"    {f} ({size} Mo)\")\n",
    "print(\"═\" * 60)\n"
   ]
  }
 ]
